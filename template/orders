{% include 'breadcrumb' %} 
<section class="signup page_customer_account">
	<div class="container">
		<div class="row">
			<div class="col-lg-3 col-12 col-left-ac">
				<div class="block-account">
					<h5 class="title-account">Trang tài khoản</h5>
					<p>
						Xin chào, <span style="color:{{settings.main_color}};">{{ customer.name }}</span>&nbsp;!
					</p>
					<ul>
						<li>
							<a disabled="disabled" class="title-info" href="/account">Thông tin tài khoản</a>
						</li>
						<li>
							<a disabled="disabled" class="title-info active" href="javascript:void(0);">Đơn hàng của bạn</a>
						</li>
						<li>
							<a class="title-info" href="/account/changepassword">Đổi mật khẩu</a>
						</li>
						<li>
							<a class="title-info" href="/account/addresses">Sổ địa chỉ ({{ customer.addresses_count }})</a>
						</li>
					</ul>
				</div>
			</div>
			<div class="col-lg-9 col-12 col-right-ac">
				<h1 class="title-head margin-top-0">Đơn hàng của bạn</h1>
				{% paginate customer.orders by 10 %}
				<div class="my-account">
					<div class="dashboard">

						<div class="recent-orders">
							<div class="table-responsive-block tab-all"style="overflow-x:auto;">
								<table class="table table-cart table-order" id="my-orders-table">
									<thead class="thead-default">
										<tr>
											<th>Đơn hàng</th>
											<th>Ngày</th>
											<th>Địa chỉ</th>
											<th>Giá trị đơn hàng</th>
											<th>Trạng thái đơn hàng</th>
											<th>Trạng thái vận chuyển</th>
										</tr>
									</thead>
<tbody>
	{% if customer.orders.size > 0 %}
		{% for order in customer.orders %}
		<tr class="first odd">
			<td>{{ order.name | link_to: order.customer_url }}</td>
			<td>{{ order.created_on | date: "dd/MM/yyyy" }}</td>
			<td>
				{% if order.shipping_address %}
					{% if order.shipping_address.address1 != null and order.shipping_address.address1 != "" %}
					{{ order.shipping_address.address1 }},
					{% endif %}
					{% if order.shipping_address.district != null and order.shipping_address.district != "" %}
					{{ order.shipping_address.district }}{{ order.shipping_address.company }},
					{% endif %} 
					{% if order.shipping_address.city != null and order.shipping_address.city != "" %}
					{{ order.shipping_address.street }} {{ order.shipping_address.city }},
					{% endif %} 
					{{ order.shipping_address.country }} <!-- {{ order.shipping_address.province }} -->
				{% endif %}
			</td>
			<td>
				<span class="price">{{ order.total_price | money }}</span>
			</td>
			<td>
				{% if order.cancelled %}
					<b style="font-weight: 600;">Đã hủy</b>
				{% else %}
					{% case order.financial_status %}
						{% when 'paid' %}
						<b class="span_{{ order.financial_status }}">
							<strong style="font-weight: 600;">Đã thanh toán</strong>
						</b>
						{% when 'authorized' %}
						<b class="span_{{ order.financial_status }}" style="font-weight: 600;">Chờ xác nhận</b>
						{% when 'pending' %}
						<b class="span_{{ order.financial_status }}" style="font-weight: 600;">Chưa thanh toán</b>
						{% when 'partially_paid' %}
						<b class="span_{{ order.financial_status }}" style="font-weight: 600;">Thanh toán một phần</b>
						{% when 'partially_refunded' %}
						<b class="span_{{ order.financial_status }}">
							<b style="font-weight: 600;">Hoàn trả một phần</b>
						</b>
						{% when 'refunded' %}
						<b class="span_{{ order.financial_status }}">
							<b style="font-weight: 600;">Hoàn trả toàn bộ</b>
						</b>
						{% when 'voided' %}
						<b class="span_{{ order.financial_status }}">Vô hiệu</b>
					{% endcase %}
				{% endif %}
			</td>
			<td>
				{% if order.cancelled %}
					<span>Đã hủy</span>
				{% else %}
					{% case order.fulfillment_status %}
						{% when 'fulfilled' %}
						<span class="span_{{ order.fulfillment_status }}">
							<strong>Chuyển toàn bộ</strong>
						</span>
						{% when 'partial' %}
						<span class="span_{{ order.fulfillment_status }}">
							<strong>Chuyển một phần</strong>
						</span>
						{% else %}
						<span class="span_{{ order.fulfillment_status }}">Chưa chuyển</span>
					{% endcase %}
				{% endif %}
			</td>
		</tr>
		{% endfor %}
	{% else %}
		<tr>
			<td colspan="6">
				<p>Không có đơn hàng nào.</p>
			</td>
		</tr>
	{% endif %}
</tbody>
								</table>

							</div>

							<div class="paginate-pages pull-right page-account text-right col-xs-12 col-sm-12 col-md-12 col-lg-12">
								{% if paginate.pages > 1 %}
								{% include 'paginate-pages' %}
								{% endif %}
							</div>
						</div>
					</div>

				</div>
				{% endpaginate %}
			</div>
		</div>
	</div>
</section>
