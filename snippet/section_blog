<section class="section_blog">
	<div class="container">
		<div class="block-title">
			<h2>
				<a href="{{settings.section_blog_url}}" title="{{settings.section_blog_title}}">{{settings.section_blog_title}}</a>
			</h2>
		</div>
		<div class="block-blog">
			{%- if blogs[settings.section_blog_url].articles_count > 0 -%}
			<div class="blog-swiper swiper-container">
				<div class="swiper-wrapper">
					{%- for article in blogs.all.articles limit: settings.section_blog_limit -%}
					<div class="swiper-slide">
						{%include 'blog_item'%}
					</div>
					{%- endfor -%}
				</div>
				{% comment %}
				<div class="swiper-button-prev"></div>
				<div class="swiper-button-next"></div>
				{% endcomment %}
			</div>
			{%- else -%}
			<div class="alert alert-warning" role="alert"><strong>{{ settings.section_blog_title }}!</strong> Đang được cập nhật nội dung.</div>
			{%- endif -%}
		</div>
	</div>
</section>
<script>
	var swiperwish = new Swiper('.blog-swiper', {
		slidesPerView: 3,
		loop: false,
		grabCursor: true,
		spaceBetween: 30,
		roundLengths: true,
		slideToClickedSlide: false,
		navigation: {
			nextEl: '.blog-swiper .swiper-button-next',
			prevEl: '.blog-swiper .swiper-button-prev',
		},
		autoplay: false,
		breakpoints: {
			300: {
				slidesPerView: 1,
				spaceBetween: 10
			},
			500: {
				slidesPerView: 1,
				spaceBetween: 10
			},
			640: {
				slidesPerView: 1,
				spaceBetween: 10
			},
			768: {
				slidesPerView: 2,
				spaceBetween: 30
			},
			991: {
				slidesPerView: 3,
				spaceBetween: 30
			},
			1200: {
				slidesPerView: 3,
				spaceBetween: 30
			}
		}
	});
</script>
