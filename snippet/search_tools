<div class="header_search">
	<form class="input-group search-bar" action="/search" method="get" role="search">
		<div class="collection-selector hidden-xs hidden-sm">
			<div class="search_text">Chọn danh mục</div>
			<div id="search_info" class="list_search" style="display: none;">
				{% for collection in collections %}  
				<div class="search_item" data-coll-id="{{collection.id}}" title="{{collection.name}}">{{collection.name | truncate: 25 }}</div>
				{%endfor%}
				<div class="liner_search"></div>
				<div class="search_item active" data-coll-id="0">Tất cả</div>
			</div>
		</div>
		<input type="search" name="query" value="" placeholder="Bạn cần tìm gì hôm nay... " class="input-group-field st-default-search-input search-text" autocomplete="off" required>
		<span class="input-group-btn">
			<button class="btn icon-fallback-text">
				<img src="{{'i_search.png' | asset_url }}" alt="{{ store.name }}" width="25" height="25"/>
			</button>
		</span>
	</form>
</div>
