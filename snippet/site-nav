<nav class="header-nav">
	<ul class="item_big">
		{%- for link in linklists[settings.main_menu].links -%}
		{%- if linklists[link.alias] != blank -%}
		<li class="nav-item {% if link.active %}active{% endif %}">
			<a class="a-img {% if linklists[link.alias].links %}caret-down{%endif%}" href="{{ link.url }}" title="{{ link.title }}">
				{{ link.title }}
			</a>
			<i class="fa fa-caret-down"></i>
			<ul class="item_small">
				{%- for link_child in linklists[link.alias].links -%}
				<li>
					<a class="{% if linklists[link_child.alias].links != blank%}caret-down{%endif%}" href="{{ link_child.url }}" title="{{ link_child.title }}">
						{{ link_child.title }} 
					</a>
					{%- if linklists[link_child.alias].links != blank -%}
					<i class="fa fa-caret-down"></i>
					{%- endif -%}
					{%- if linklists[link_child.alias].links -%}
					<ul>
						{%- for link_child2 in linklists[link_child.alias].links -%}
						<li>
							<a href="{{ link_child2.url }}" title="{{ link_child2.title }}" class="a3">{{ link_child2.title }}</a>
						</li>
						{%- endfor -%}
					</ul>
					{%- endif -%}
				</li>
				{%- endfor -%}
			</ul>
		</li>
		{%- else -%}
		<li class="nav-item {% if link.active %}active {% endif %}">				
			<a class="a-img" href="{{ link.url }}" title="{{ link.title }}">
				{{ link.title }}
			</a>
		</li>
		{%- endif -%}
		{%- endfor -%}
	</ul>
</nav>
