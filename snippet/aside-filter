					{% assign tag_value = tag | handleize %}
					<li class="filter-item filter-item--check-box filter-item--green">
						<span>
							<label for="filter-{{ tag | handleize }}">
								<input type="checkbox" id="filter-{{ tag | handleize }}" data-group="tag5" data-field="tags" data-text="{{ tag }}" value="({{ tag }})" data-operator="OR">
								<i class="fa"></i>
