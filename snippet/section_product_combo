<!-- Bổ sung class 'section_product_featured' vào đây để "ké" CSS của nút gốc -->
<section class="section_product_combo section_product_featured module_product"> 
	<div class="container">
		<div class="block-title">
			<h2>
				<a href="{{settings.section_combo_url}}" title="{{settings.section_combo_title}}">{{settings.section_combo_title}}</a>
			</h2>
		</div>
		<div class="block-product">
			{%- if collections[settings.section_combo_url].products.size > 0 -%}
			<div class="row">
				{%- for product in collections[settings.section_combo_url].products limit: settings.section_combo_limit -%}
				<div class="item col-md-3 col-6">
					{%- include 'product_grid_office' -%}	
				</div>
				{%- endfor -%}
			</div>
            
			<!-- Trả lại cái nút về nguyên bản (Không có chữ style dài ngoằng nữa) -->
			<div class="view-more">
				<a href="{{settings.section_combo_url}}" title="Xem tất cả">Xem tất cả</a>
			</div>

			{%- else -%}
			<div class="alert alert-warning" role="alert"><strong>{{ settings.section_combo_title }}!</strong> Đang được cập nhật nội dung.</div>
			{%- endif -%}
		</div>
	</div>
</section>section_product_combsection_product_comb
