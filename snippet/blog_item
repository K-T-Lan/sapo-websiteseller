<div class="item-blog">
	<div class="block-thumb">
		{% if article.image != null %}
		<a class="thumb" href="{{ article.url }}" title="{{ article.title }}">
			<img class="lazyload" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAAXNSR0IArs4c6QAAAARnQU1BAACxjwv8YQUAAAAJcEhZcwAADsQAAA7EAZUrDhsAAAANSURBVBhXYzh8+PB/AAffA0nNPuCLAAAAAElFTkSuQmCC" 
				 data-src="{{ article.image.src}}"  alt="{{ article.title }}">
		</a>
		{%else%}
		<a class="thumb" href="{{ article.url }}">
			<img class="lazyload" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAAAXNSR0IArs4c6QAAAARnQU1BAACxjwv8YQUAAAAJcEhZcwAADsQAAA7EAZUrDhsAAAANSURBVBhXYzh8+PB/AAffA0nNPuCLAAAAAElFTkSuQmCC" 
				 data-src="{{ 'no-image.jpg' | asset_url}}" alt="{{ article.title }}" title="{{ article.title }}"/>
		</a>
		{% endif %}
	</div>
	<div class="block-content">
		<h3>
			<a href="{{ article.url }}" title="{{ article.title }}">{{ article.title }}</a>
		</h3>
		<div class="time-post f">
			{%assign thu = article.published_on | date:'%a' %}
			<svg aria-hidden="true" focusable="false" data-prefix="fal" data-icon="clock" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="svg-inline--fa fa-clock fa-w-16"><path fill="currentColor" d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm216 248c0 118.7-96.1 216-216 216-118.7 0-216-96.1-216-216 0-118.7 96.1-216 216-216 118.7 0 216 96.1 216 216zm-148.9 88.3l-81.2-59c-3.1-2.3-4.9-5.9-4.9-9.7V116c0-6.6 5.4-12 12-12h14c6.6 0 12 5.4 12 12v146.3l70.5 51.3c5.4 3.9 6.5 11.4 2.6 16.8l-8.2 11.3c-3.9 5.3-11.4 6.5-16.8 2.6z" class=""></path></svg>
			{%if thu == 'Mon'%}
			Thứ Hai,
			{%elsif thu == 'Tue'%}
			Thứ Ba,
			{%elsif thu == 'Wed'%}
			Thứ Tư,
			{%elsif thu == 'Thu'%}
			Thứ Năm,
			{%elsif thu == 'Fri'%}
			Thứ Sáu,
			{%elsif thu == 'Sat'%}
			Thứ Bảy,
			{%elsif thu == 'Sun'%}
			Chủ Nhật,
			{%else%}
			Thứ {{ article.published_on | date:'%a' }}
			{%endif%}{{ article.published_on | date:'dd/MM/yyy' }}
		</div>
		<div class="time-post">
			<svg aria-hidden="true" focusable="false" data-prefix="fas" data-icon="user" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="svg-inline--fa fa-user fa-w-14"><path fill="currentColor" d="M224 256c70.7 0 128-57.3 128-128S294.7 0 224 0 96 57.3 96 128s57.3 128 128 128zm89.6 32h-16.7c-22.2 10.2-46.9 16-72.9 16s-50.6-5.8-72.9-16h-16.7C60.2 288 0 348.2 0 422.4V464c0 26.5 21.5 48 48 48h352c26.5 0 48-21.5 48-48v-41.6c0-74.2-60.2-134.4-134.4-134.4z" class=""></path></svg>
			<span>{{article.author}}</span>
		</div>
		<p class="justify">{{ article.content | strip_html | truncatewords: 25 }}
		</p>
		{%if article.content != null and article.content != ""%}
		<a class="viewmore" href="{{ article.url }}" title="Đọc tiếp">Đọc tiếp</a>
		{%endif%}
	</div>
</div>
